<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InstogramApp.Controls.AsyncImage"
             x:Name="Root">
  <Panel>
    <Border IsVisible="{Binding #Root.IsLoading}"
            Background="#111111" MinHeight="120">
      <TextBlock Text="Loading…" FontSize="13"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Foreground="#666666"/>
    </Border>
    <Image Source="{Binding #Root.BitmapSource}"
           Stretch="Uniform"/>
  </Panel>
</UserControl>
