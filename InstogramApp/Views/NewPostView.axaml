<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="using:InstogramApp.Controls"
             x:Class="InstogramApp.Views.NewPostView">

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid VerticalAlignment="Top" HorizontalAlignment="Center" Width="560" Margin="0,28,0,36">
      <Border Background="{DynamicResource AppCardBrush}" CornerRadius="20" Padding="36,32"
              BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
        <StackPanel Spacing="20">

          <StackPanel Spacing="4">
            <TextBlock Text="Create Post" Foreground="{DynamicResource AppTextBrush}"
                       FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Share something with the world" Foreground="{DynamicResource AppSubtextBrush}" FontSize="13"/>
          </StackPanel>

          <Border Height="1" Background="{DynamicResource AppBorderBrush}" Opacity="0.6"/>

          <!-- Caption -->
          <StackPanel Spacing="6">
            <TextBlock Text="CAPTION" Foreground="{DynamicResource AppSubtextBrush}" FontSize="11"
                       FontWeight="SemiBold" LetterSpacing="1.2"/>
            <TextBox Text="{Binding Caption}"
                     PlaceholderText="What's on your mind? Use #hashtags to tag topics."
                     AcceptsReturn="True" MinHeight="100" MaxHeight="220"
                     TextWrapping="Wrap" Classes="postInput"/>
          </StackPanel>

          <!-- Image / Video area -->
          <StackPanel Spacing="8">
            <TextBlock Text="PHOTO OR VIDEO" Foreground="{DynamicResource AppSubtextBrush}" FontSize="11"
                       FontWeight="SemiBold" LetterSpacing="1.2"/>

            <!-- Image preview -->
            <Border CornerRadius="12" ClipToBounds="True" IsVisible="{Binding HasImage}"
                    MaxHeight="340" BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1">
              <Grid>
                <ctl:AsyncImage Source="{Binding ImagePath}"/>
                <Button Click="OnRemoveImage" Classes="removeBtn"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="10" Content="✕ Remove"/>
              </Grid>
            </Border>

            <!-- Video chosen indicator -->
            <Border CornerRadius="12" IsVisible="{Binding HasVideo}"
                    Background="{DynamicResource AppInputBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                    Padding="16,14">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <Viewbox Grid.Column="0" Width="28" Height="28">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource AppAccentBrush}"
                          Data="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/>
                  </Canvas>
                </Viewbox>
                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="Video selected" Foreground="{DynamicResource AppTextBrush}"
                             FontWeight="SemiBold" FontSize="13"/>
                  <TextBlock Text="{Binding VideoPath}" Foreground="#555555"
                             FontSize="11" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button Grid.Column="2" Click="OnRemoveVideo" Classes="removeBtn" Content="✕ Remove"/>
              </Grid>
            </Border>

            <!-- Pick buttons (shown when neither image nor video is selected) -->
            <Grid ColumnDefinitions="*,8,*"
                  IsVisible="{Binding CanPickMedia}">
              <Button Grid.Column="0" Click="OnPickImage" Classes="imagePickBtn">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                  <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                    <Canvas Width="24" Height="24">
                      <Path Fill="#555555"
                            Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </Canvas>
                  </Viewbox>
                  <TextBlock Text="Add Photo" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center"/>
                  <TextBlock Text="PNG, JPG, WebP" FontSize="10" Foreground="#555555" HorizontalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Grid.Column="2" Click="OnPickVideo" Classes="imagePickBtn">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                  <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                    <Canvas Width="24" Height="24">
                      <Path Fill="#555555"
                            Data="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/>
                    </Canvas>
                  </Viewbox>
                  <TextBlock Text="Add Video" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center"/>
                  <TextBlock Text="MP4, WebM, MOV" FontSize="10" Foreground="#555555" HorizontalAlignment="Center"/>
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>

          <!-- Suggested tags (from typed #hashtags) -->
          <StackPanel Spacing="8" IsVisible="{Binding HasSuggestedTags}">
            <TextBlock Text="DETECTED TAGS" Foreground="#555555" FontSize="11"
                       FontWeight="SemiBold" LetterSpacing="0.8"/>
            <ItemsControl ItemsSource="{Binding SuggestedTags}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Click="OnTagChipClick" Tag="{Binding}"
                          Classes="tagChip" Margin="0,0,6,6"
                          Content="{Binding Tag, StringFormat='#{0}'}"
                          Background="{Binding ChipBackground}"
                          Foreground="{Binding ChipForeground}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- Premade tags -->
          <StackPanel Spacing="8">
            <TextBlock Text="QUICK TAGS" Foreground="#555555" FontSize="11"
                       FontWeight="SemiBold" LetterSpacing="0.8"/>
            <ItemsControl ItemsSource="{Binding PremadeTags}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Click="OnTagChipClick" Tag="{Binding}"
                          Classes="tagChip" Margin="0,0,6,6"
                          Content="{Binding Tag, StringFormat='#{0}'}"
                          Background="{Binding ChipBackground}"
                          Foreground="{Binding ChipForeground}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- Status / error -->
          <Border Background="#100a20" CornerRadius="10" Padding="14,10"
                  BorderBrush="#2a1a50" BorderThickness="1"
                  IsVisible="{Binding Status,
                  Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding Status}" Foreground="#a78bfa"
                       FontSize="13" TextWrapping="Wrap"/>
          </Border>

          <!-- Progress -->
          <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}"
                       Height="3" Foreground="#8b5cf6"
                       Background="{DynamicResource AppInputBrush}" CornerRadius="2"/>

          <Border Height="1" Background="{DynamicResource AppBorderBrush}" Opacity="0.6"/>

          <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Click="OnSubmit" Content="Share Post" Classes="primaryBtn" Width="150"/>
            <Button Click="OnCancel" Content="Discard"    Classes="cancelBtn"  Width="100"/>
          </StackPanel>

        </StackPanel>
      </Border>
    </Grid>
  </ScrollViewer>

  <UserControl.Styles>
    <Style Selector="TextBox.postInput">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="TextBox.postInput /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
    </Style>
    <Style Selector="TextBox.postInput:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
    </Style>
    <Style Selector="TextBox.postInput:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.postInput:focus-within /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.postInput /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="#555555"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.primaryBtn">
      <Setter Property="Background" Value="#7c3aed"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.primaryBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#6d28d9"/>
    </Style>
    <Style Selector="Button.cancelBtn">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.imagePickBtn">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="20,18"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.imagePickBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1a1a2e"/>
    </Style>
    <Style Selector="Button.removeBtn">
      <Setter Property="Background" Value="#dd000000"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="8,5"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.tagChip">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="CornerRadius" Value="20"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#2a2a4a"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </UserControl.Styles>
</UserControl>
