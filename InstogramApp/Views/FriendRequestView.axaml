<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InstogramApp.ViewModels"
             x:Class="InstogramApp.Views.FriendRequestView">

  <Grid RowDefinitions="Auto,*">

    <!-- Top bar -->
    <Border Grid.Row="0" Background="{DynamicResource AppSurfaceBrush}" Padding="24,16"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
      <StackPanel Spacing="14">

        <TextBlock Text="Friends" Foreground="{DynamicResource AppTextBrush}"
                   FontSize="22" FontWeight="Bold"/>

        <!-- Tab switcher -->
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button Click="OnFriendsTab"  Classes="tabSwitchBtn" Content="Friends"
                  Tag="{Binding ShowFriends}"/>
          <Button Click="OnIncomingTab" Classes="tabSwitchBtn" Content="Incoming"
                  Tag="{Binding ShowIncoming}"/>
          <Button Click="OnOutgoingTab" Classes="tabSwitchBtn" Content="Sent"
                  Tag="{Binding ShowOutgoing}"/>
        </StackPanel>

      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1" Padding="28,20,28,28">
      <StackPanel MaxWidth="700" HorizontalAlignment="Center" Spacing="0">

        <!-- ── FRIENDS tab ─────────────────────────────────────────────── -->
        <StackPanel IsVisible="{Binding ShowFriends}" Spacing="0">

          <TextBlock Text="No friends yet. Send a friend request from someone's profile."
                     Foreground="#444444" FontSize="14" HorizontalAlignment="Center"
                     Margin="0,40" TextWrapping="Wrap" TextAlignment="Center"
                     IsVisible="{Binding NoFriends}"/>

          <ItemsControl ItemsSource="{Binding Friends}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:FriendRowViewModel}">
                <Border Background="{DynamicResource AppCardBrush}" CornerRadius="12"
                        Margin="0,0,0,10" Padding="16,14"
                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                  <Grid ColumnDefinitions="46,*,Auto">

                    <!-- Avatar -->
                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="21"
                            Background="{Binding AccentColor}" Cursor="Hand">
                      <TextBlock Text="{Binding AvatarLetter}" Foreground="White"
                                 FontWeight="Bold" FontSize="18"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Name -->
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" Spacing="2">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                        <Border Background="#1d4ed8" CornerRadius="4" Padding="5,1"
                                IsVisible="{Binding IsMaster}" VerticalAlignment="Center">
                          <TextBlock Text="MASTER" Foreground="White" FontSize="9" FontWeight="Bold"/>
                        </Border>
                        <Border Background="#7c3aed" CornerRadius="4" Padding="5,1"
                                IsVisible="{Binding IsVerified}" VerticalAlignment="Center">
                          <TextBlock Text="✓" Foreground="White" FontSize="9" FontWeight="Bold"/>
                        </Border>
                      </StackPanel>
                      <TextBlock Text="{Binding AtUsername}" Foreground="#555555" FontSize="13"/>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">
                      <Button Click="OnFriendCall"    Tag="{Binding}" Content="Call"    Classes="callFriendBtn"/>
                      <Button Click="OnFriendMessage" Tag="{Binding}" Content="Message" Classes="msgFriendBtn"/>
                      <Button Click="OnFriendProfile" Tag="{Binding}" Content="Profile" Classes="viewFriendBtn"/>
                    </StackPanel>

                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- ── INCOMING tab ─────────────────────────────────────────────── -->
        <StackPanel IsVisible="{Binding ShowIncoming}" Spacing="0">

          <TextBlock Text="No incoming friend requests." Foreground="#444444"
                     FontSize="14" HorizontalAlignment="Center" Margin="0,40"
                     IsVisible="{Binding NoIncoming}"/>

          <ItemsControl ItemsSource="{Binding Incoming}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:FriendRequestRowViewModel}">
                <Border Background="{DynamicResource AppCardBrush}" CornerRadius="12" Padding="16"
                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                        Margin="0,0,0,10">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                            Background="{Binding AccentColor}" Margin="0,0,12,0">
                      <TextBlock Text="{Binding AvatarLetter}" Foreground="White"
                                 FontWeight="Bold" FontSize="18"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource AppTextBrush}"
                                 FontSize="15" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding Username, StringFormat='@{0}'}"
                                 Foreground="#666666" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding ActionResult}"
                               Foreground="#a78bfa" FontSize="13" VerticalAlignment="Center"
                               IsVisible="{Binding IsActioned}"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding IsNotActioned}">
                      <Button Click="OnAccept"  Tag="{Binding}" Content="Accept"
                              Background="#7c3aed" Foreground="White"
                              Padding="14,7" CornerRadius="8" FontSize="13"
                              Cursor="Hand" BorderThickness="0"/>
                      <Button Click="OnDecline" Tag="{Binding}" Content="Decline"
                              Background="{DynamicResource AppInputBrush}" Foreground="#aaaaaa"
                              Padding="14,7" CornerRadius="8" FontSize="13"
                              Cursor="Hand" BorderThickness="0"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- ── SENT tab ─────────────────────────────────────────────────── -->
        <StackPanel IsVisible="{Binding ShowOutgoing}" Spacing="0">

          <TextBlock Text="No outgoing friend requests." Foreground="#444444"
                     FontSize="14" HorizontalAlignment="Center" Margin="0,40"
                     IsVisible="{Binding NoOutgoing}"/>

          <ItemsControl ItemsSource="{Binding Outgoing}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:FriendRequestRowViewModel}">
                <Border Background="{DynamicResource AppCardBrush}" CornerRadius="12" Padding="16"
                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                        Margin="0,0,0,10">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                            Background="#333333" Margin="0,0,12,0">
                      <TextBlock Text="{Binding AvatarLetter}" Foreground="White"
                                 FontWeight="Bold" FontSize="18"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource AppTextBrush}"
                                 FontSize="15" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding Username, StringFormat='@{0}'}"
                                 Foreground="#666666" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="Pending" Foreground="#555555"
                               FontSize="13" VerticalAlignment="Center"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

  </Grid>

  <UserControl.Styles>
    <Style Selector="Button.tabSwitchBtn">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Padding" Value="20,9"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.callFriendBtn">
      <Setter Property="Background" Value="#166534"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.msgFriendBtn">
      <Setter Property="Background" Value="#7c3aed"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.viewFriendBtn">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </UserControl.Styles>
</UserControl>
