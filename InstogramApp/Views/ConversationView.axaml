<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InstogramApp.ViewModels"
             x:Class="InstogramApp.Views.ConversationView">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource AppSurfaceBrush}" Padding="16,12"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <Button Click="OnBack" Classes="ghostBtn">
            <Viewbox Width="18" Height="18">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource AppSubtextBrush}"
                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
              </Canvas>
            </Viewbox>
          </Button>
          <Border Width="40" Height="40" CornerRadius="20"
                  Background="{DynamicResource AppAccentBrush}">
            <TextBlock Text="{Binding AvatarLetter}" Foreground="White" FontWeight="Bold"
                       FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <Button Click="OnViewProfile" Classes="ghostBtn" Padding="0">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding Partner.DisplayName}" Foreground="{DynamicResource AppTextBrush}"
                         FontWeight="SemiBold" FontSize="14"/>
              <TextBlock Text="{Binding Partner.Username, StringFormat='@{0}'}"
                         Foreground="{DynamicResource AppSubtextBrush}" FontSize="12"/>
            </StackPanel>
          </Button>
        </StackPanel>
        <Button Grid.Column="1" Click="OnCall" Classes="callHeaderBtn">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Viewbox Width="14" Height="14">
              <Canvas Width="24" Height="24">
                <Path Fill="White"
                      Data="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </Canvas>
            </Viewbox>
            <TextBlock Text="Call" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Message bubbles -->
    <ScrollViewer Grid.Row="1" Padding="16,12">
      <ItemsControl ItemsSource="{Binding Messages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,3">
              <!-- Mine: right-aligned purple -->
              <Border HorizontalAlignment="Right" MaxWidth="340"
                      Background="#7c3aed" CornerRadius="16,16,4,16"
                      Padding="12,8" IsVisible="{Binding IsMine}">
                <StackPanel Spacing="3">
                  <TextBlock Text="{Binding Text}" Foreground="{DynamicResource AppTextBrush}"
                             FontSize="14" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding Time}" Foreground="#c4b5fd"
                             FontSize="10" HorizontalAlignment="Right"/>
                </StackPanel>
              </Border>
              <!-- Theirs: left-aligned dark -->
              <Border HorizontalAlignment="Left" MaxWidth="340"
                      Background="{DynamicResource AppInputBrush}" CornerRadius="16,16,16,4"
                      Padding="12,8" IsVisible="{Binding IsNotMine}">
                <StackPanel Spacing="3">
                  <TextBlock Text="{Binding Text}" Foreground="#eeeeee"
                             FontSize="14" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding Time}" Foreground="#555555"
                             FontSize="10" HorizontalAlignment="Left"/>
                </StackPanel>
              </Border>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Compose bar -->
    <Border Grid.Row="2" Background="{DynamicResource AppSurfaceBrush}" Padding="16,10"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0" Text="{Binding NewMessage}"
                 PlaceholderText="Message…"
                 Classes="composeInput"/>
        <Button Grid.Column="1" Click="OnSend" Classes="sendBtn" Margin="10,0,0,0">
          <Viewbox Width="16" Height="16">
            <Canvas Width="24" Height="24">
              <Path Fill="White" Data="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
            </Canvas>
          </Viewbox>
        </Button>
      </Grid>
    </Border>

  </Grid>

  <UserControl.Styles>
    <Style Selector="Button.ghostBtn">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="Padding" Value="8,8"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.ghostBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
    </Style>
    <Style Selector="TextBox.composeInput">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="Padding" Value="16,11"/>
      <Setter Property="CornerRadius" Value="22"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="TextBox.composeInput /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.composeInput:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.composeInput:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.composeInput:focus-within /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.composeInput /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.callHeaderBtn">
      <Setter Property="Background" Value="#166534"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="14,9"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.callHeaderBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#14532d"/>
    </Style>
    <Style Selector="Button.sendBtn">
      <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="14,11"/>
      <Setter Property="CornerRadius" Value="22"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.sendBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppAccentDimBrush}"/>
    </Style>
  </UserControl.Styles>
</UserControl>
