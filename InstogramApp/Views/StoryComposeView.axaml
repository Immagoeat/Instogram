<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InstogramApp.Views.StoryComposeView">

  <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="460">
    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="16" Padding="32"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
      <StackPanel Spacing="18">

        <StackPanel Spacing="4">
          <TextBlock Text="New Story" Foreground="{DynamicResource AppTextBrush}" FontSize="22" FontWeight="Bold"/>
          <TextBlock Text="Visible for 24 hours to your followers"
                     Foreground="#444444" FontSize="13"/>
        </StackPanel>

        <!-- Live preview -->
        <Border CornerRadius="14" Height="180" Padding="20"
                Background="{Binding SelectedColor}">
          <TextBlock Text="{Binding Text}" Foreground="{DynamicResource AppTextBrush}" FontSize="18"
                     FontWeight="Medium" TextWrapping="Wrap"
                     VerticalAlignment="Center" HorizontalAlignment="Center"
                     TextAlignment="Center"/>
        </Border>

        <TextBox Text="{Binding Text}"
                 PlaceholderText="What's your story?"
                 AcceptsReturn="True" MinHeight="80" MaxHeight="160"
                 TextWrapping="Wrap" Classes="darkInput"/>

        <!-- Background colour picker -->
        <StackPanel Spacing="6">
          <TextBlock Text="Background" Foreground="#666666" FontSize="12"/>
          <ItemsControl ItemsSource="{Binding BackgroundOptions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Click="OnSelectColor" Tag="{Binding}"
                        Width="36" Height="36" Margin="0,0,8,0"
                        CornerRadius="18" Padding="0" Cursor="Hand"
                        Background="{Binding}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="#ff8080" FontSize="13"
                   IsVisible="{Binding ErrorMessage,
                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <StackPanel Orientation="Horizontal" Spacing="10">
          <Button Click="OnPost"   Content="Share Story" Classes="primaryBtn" Width="150"/>
          <Button Click="OnCancel" Content="Discard"     Classes="cancelBtn"  Width="100"/>
        </StackPanel>

      </StackPanel>
    </Border>
  </Grid>

  <UserControl.Styles>
    <Style Selector="TextBox.darkInput">
      <Setter Property="Background" Value="#1a1a1a"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#2a2a2a"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="Button.primaryBtn">
      <Setter Property="Background" Value="#8b5cf6"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="14,11"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.cancelBtn">
      <Setter Property="Background" Value="#1e1e1e"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="14,11"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
  </UserControl.Styles>
</UserControl>
