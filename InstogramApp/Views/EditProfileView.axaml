<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:InstogramApp.Converters"
             x:Class="InstogramApp.Views.EditProfileView">

  <UserControl.Resources>
    <conv:PathToBitmapConverter x:Key="PathToBitmap"/>
  </UserControl.Resources>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <Grid HorizontalAlignment="Center" Width="520" Margin="0,28,0,28">
      <StackPanel Spacing="20">

        <!-- Header -->
        <Grid ColumnDefinitions="Auto,*">
          <Button Grid.Column="0" Click="OnBack" Classes="ghostBtn" Padding="8,8">
            <Viewbox Width="18" Height="18">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource AppSubtextBrush}"
                      Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
              </Canvas>
            </Viewbox>
          </Button>
          <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="Edit Profile" Foreground="{DynamicResource AppTextBrush}"
                       FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Customize how others see you"
                       Foreground="{DynamicResource AppSubtextBrush}" FontSize="12"/>
          </StackPanel>
        </Grid>

        <!-- ── Avatar ──────────────────────────────────────────────────── -->
        <Border Background="{DynamicResource AppCardBrush}" CornerRadius="14" Padding="24"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
          <StackPanel Spacing="14">
            <TextBlock Text="PROFILE PICTURE" Foreground="{DynamicResource AppSubtextBrush}"
                       FontSize="11" FontWeight="SemiBold" LetterSpacing="1"/>

            <Grid ColumnDefinitions="Auto,*">
              <!-- Preview circle -->
              <Grid Grid.Column="0" Width="90" Height="90">
                <!-- Image avatar -->
                <Border CornerRadius="45" ClipToBounds="True"
                        IsVisible="{Binding HasAvatar}"
                        Width="90" Height="90">
                  <Image Source="{Binding AvatarPath, Converter={StaticResource PathToBitmap}}"
                         Stretch="UniformToFill"
                         Width="90" Height="90"/>
                </Border>
                <!-- Initials fallback -->
                <Border Width="90" Height="90" CornerRadius="45"
                        Background="{Binding SelectedColor}"
                        IsVisible="{Binding HasNoAvatar}">
                  <TextBlock Text="{Binding DisplayName[0]}" Foreground="{DynamicResource AppTextBrush}"
                             FontWeight="Bold" FontSize="36"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </Grid>

              <!-- Buttons -->
              <StackPanel Grid.Column="1" Margin="18,0,0,0"
                          VerticalAlignment="Center" Spacing="10">
                <Button Click="OnPickAvatar" Classes="primaryBtn"
                        Content="Upload Image" HorizontalAlignment="Left"
                        Padding="18,9"/>
                <Button Click="OnClearAvatar" Classes="ghostBtn"
                        Content="Remove photo" HorizontalAlignment="Left"
                        IsVisible="{Binding HasAvatar}"
                        Foreground="#ff6b6b" FontSize="13"/>
                <TextBlock Text="PNG, JPG, GIF, WEBP · max 5 MB"
                           Foreground="{DynamicResource AppSubtextBrush}" FontSize="11"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- ── Profile info ────────────────────────────────────────────── -->
        <Border Background="{DynamicResource AppCardBrush}" CornerRadius="14" Padding="24"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
          <StackPanel Spacing="14">
            <TextBlock Text="PROFILE INFO" Foreground="{DynamicResource AppSubtextBrush}"
                       FontSize="11" FontWeight="SemiBold" LetterSpacing="1"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"    Classes="label"/>
              <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding DisplayName}"
                         Classes="field" Margin="0,0,0,10"/>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Bio"     Classes="label"/>
              <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Bio}"
                         PlaceholderText="Tell the world about yourself…"
                         AcceptsReturn="True" MinHeight="70"
                         Classes="field" Margin="0,0,0,10" TextWrapping="Wrap"/>

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Website" Classes="label"/>
              <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Website}"
                         PlaceholderText="https://…"
                         Classes="field" Margin="0,0,0,10"/>

              <TextBlock Grid.Row="3" Grid.Column="0" Text="Email"   Classes="label"/>
              <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding Email}"
                         Classes="field" Margin="0,0,0,10"/>

              <TextBlock Grid.Row="4" Grid.Column="0" Text="Phone"   Classes="label"/>
              <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Phone}"
                         Classes="field"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- ── Accent colour ───────────────────────────────────────────── -->
        <Border Background="{DynamicResource AppCardBrush}" CornerRadius="14" Padding="24"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
          <StackPanel Spacing="14">
            <TextBlock Text="ACCENT COLOUR" Foreground="{DynamicResource AppSubtextBrush}"
                       FontSize="11" FontWeight="SemiBold" LetterSpacing="1"/>
            <TextBlock Text="Used for your avatar background and highlights when no photo is set"
                       Foreground="{DynamicResource AppSubtextBrush}" FontSize="12" TextWrapping="Wrap"/>

            <!-- Selected colour preview strip -->
            <Grid ColumnDefinitions="Auto,*">
              <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                      Background="{Binding SelectedColor}" Margin="0,0,12,0"/>
              <TextBlock Grid.Column="1" Text="{Binding SelectedColor}"
                         Foreground="{DynamicResource AppSubtextBrush}"
                         FontSize="13" FontFamily="Consolas,Monospace"
                         VerticalAlignment="Center"/>
            </Grid>

            <!-- Colour swatches — 5 per row -->
            <ItemsControl ItemsSource="{Binding AccentColors}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Width="48" Height="48" Margin="0,0,8,8">
                    <!-- Colour circle -->
                    <Button Click="OnSelectColor" Tag="{Binding}"
                            Width="40" Height="40" Margin="4"
                            CornerRadius="20" Padding="0" Cursor="Hand"
                            Background="{Binding}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Custom hex input -->
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBox Text="{Binding SelectedColor}"
                       PlaceholderText="#rrggbb"
                       Width="110" Classes="field"
                       FontFamily="Consolas,Monospace"/>
              <TextBlock Text="or type any hex color"
                         Foreground="{DynamicResource AppSubtextBrush}" FontSize="12"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ── Notifications ───────────────────────────────────────────── -->
        <Border Background="{DynamicResource AppCardBrush}" CornerRadius="14" Padding="24"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
          <StackPanel Spacing="14">
            <TextBlock Text="NOTIFICATIONS" Foreground="{DynamicResource AppSubtextBrush}"
                       FontSize="11" FontWeight="SemiBold" LetterSpacing="1"/>

            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Direct messages" Foreground="{DynamicResource AppTextBrush}" FontSize="14"/>
                <TextBlock Text="Get notified when someone messages you"
                           Foreground="{DynamicResource AppSubtextBrush}" FontSize="12"/>
              </StackPanel>
              <CheckBox Grid.Column="1" IsChecked="{Binding NotifyDMs}"
                        VerticalAlignment="Center"/>
            </Grid>

            <Border Height="1" Background="{DynamicResource AppBorderBrush}"/>

            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Posts from people you follow" Foreground="{DynamicResource AppTextBrush}" FontSize="14"/>
                <TextBlock Text="Get notified when someone you follow posts"
                           Foreground="{DynamicResource AppSubtextBrush}" FontSize="12"/>
              </StackPanel>
              <CheckBox Grid.Column="1" IsChecked="{Binding NotifyFollowedPosts}"
                        VerticalAlignment="Center"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Feedback -->
        <TextBlock Text="{Binding Status}" Foreground="{DynamicResource AppAccentBrush}"
                   FontSize="14"
                   IsVisible="{Binding Status,
                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        <TextBlock Text="{Binding ErrorMessage}" Foreground="#ff8080" FontSize="14"
                   IsVisible="{Binding ErrorMessage,
                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <!-- Theme + Save row -->
        <Grid ColumnDefinitions="Auto,*">
          <Button Grid.Column="0" Click="OnGoThemes" Classes="themeBtn"
                  Margin="0,0,12,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Viewbox Width="16" Height="16">
                <Canvas Width="24" Height="24">
                  <Path Fill="{DynamicResource AppAccentBrush}"
                        Data="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9c.83 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1.01-.23-.26-.38-.61-.38-.99 0-.83.67-1.5 1.5-1.5H16c2.76 0 5-2.24 5-5 0-4.42-4.03-8-9-8zm-5.5 9c-.83 0-1.5-.67-1.5-1.5S5.67 9 6.5 9 8 9.67 8 10.5 7.33 12 6.5 12zm3-4C8.67 8 8 7.33 8 6.5S8.67 5 9.5 5s1.5.67 1.5 1.5S10.33 8 9.5 8zm5 0c-.83 0-1.5-.67-1.5-1.5S13.67 5 14.5 5s1.5.67 1.5 1.5S15.33 8 14.5 8zm3 4c-.83 0-1.5-.67-1.5-1.5S16.67 9 17.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
                </Canvas>
              </Viewbox>
              <TextBlock Text="Theme" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="1" Click="OnSave" Classes="primaryBtn"
                  HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <Viewbox Width="14" Height="14">
                <Canvas Width="24" Height="24">
                  <Path Fill="White"
                        Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </Canvas>
              </Viewbox>
              <TextBlock Text="Save Changes" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </Grid>

      </StackPanel>
    </Grid>
  </ScrollViewer>

  <UserControl.Styles>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
      <Setter Property="Margin" Value="0,10,16,0"/>
      <Setter Property="Width" Value="70"/>
    </Style>
    <Style Selector="TextBox.field">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="Padding" Value="12,9"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="TextBox.field /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.field:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.field:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.field:focus-within /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.field /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.primaryBtn">
      <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="14,12"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.primaryBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppAccentDimBrush}"/>
    </Style>
    <Style Selector="Button.ghostBtn">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="Padding" Value="8,8"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="Button.ghostBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
    </Style>
    <Style Selector="Button.themeBtn">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.themeBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
    </Style>
  </UserControl.Styles>
</UserControl>
