<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InstogramApp.Views.FeedView">

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Top bar -->
    <Border Grid.Row="0" Background="{DynamicResource AppSurfaceBrush}" Padding="28,18"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
          <TextBlock Text="Feed" Foreground="{DynamicResource AppTextBrush}"
                     FontSize="24" FontWeight="Bold" LetterSpacing="0.2"/>
          <TextBlock Text="Latest from people you follow"
                     Foreground="{DynamicResource AppSubtextBrush}" FontSize="12"/>
        </StackPanel>
        <Button Grid.Column="1" Click="DoRefresh" Classes="refreshBtn">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <Viewbox Width="14" Height="14">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource NavIconBrush}"
                      Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
              </Canvas>
            </Viewbox>
            <TextBlock Text="Refresh" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Story strip -->
    <Border Grid.Row="1" Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1"
            Padding="28,14,28,20"
            IsVisible="{Binding HasStories}">
      <StackPanel Spacing="12">
        <TextBlock Text="STORIES" Foreground="{DynamicResource AppSubtextBrush}" FontSize="10"
                   FontWeight="SemiBold" LetterSpacing="1.5"/>
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding Stories}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="16"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Click="OnOpenStory" Tag="{Binding}"
                        Classes="storyBubbleBtn">
                  <StackPanel Spacing="7" HorizontalAlignment="Center" Width="72">
                    <Grid Width="64" Height="64">
                      <!-- Gradient ring (unseen) -->
                      <Border Width="64" Height="64" CornerRadius="32"
                              BorderThickness="2.5"
                              IsVisible="{Binding HasUnseen}">
                        <Border.BorderBrush>
                          <LinearGradientBrush StartPoint="45%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#7c3aed" Offset="0"/>
                            <GradientStop Color="#a855f7" Offset="0.4"/>
                            <GradientStop Color="#ec4899" Offset="1"/>
                          </LinearGradientBrush>
                        </Border.BorderBrush>
                      </Border>
                      <!-- Muted ring (seen) -->
                      <Border Width="64" Height="64" CornerRadius="32"
                              BorderThickness="2" BorderBrush="{DynamicResource AppBorderBrush}"
                              IsVisible="{Binding !HasUnseen}"/>
                      <!-- Avatar -->
                      <Border Width="56" Height="56" CornerRadius="28"
                              Background="{Binding AccentColor}"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Initial}" Foreground="White"
                                   FontWeight="Bold" FontSize="24"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                    </Grid>
                    <TextBlock Text="{Binding AuthorUsername}"
                               Foreground="{DynamicResource AppSubtextBrush}"
                               FontSize="11" HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </StackPanel>
    </Border>

    <!-- Posts -->
    <ScrollViewer Grid.Row="2" Padding="32,24,32,32">
      <StackPanel MaxWidth="700" HorizontalAlignment="Center">
        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}"
                     Height="3" Foreground="{DynamicResource AppAccentBrush}"
                     Background="{DynamicResource AppInputBrush}"
                     CornerRadius="2" Margin="0,0,0,20"/>

        <!-- Empty state -->
        <StackPanel IsVisible="{Binding NoPosts}" HorizontalAlignment="Center"
                    Spacing="16" Margin="0,100">
          <Border Width="72" Height="72" CornerRadius="36"
                  HorizontalAlignment="Center">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#1e0d40" Offset="0"/>
                <GradientStop Color="#2d0a28" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <Viewbox Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
              <Canvas Width="24" Height="24">
                <Path Fill="#4a3080"
                      Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
              </Canvas>
            </Viewbox>
          </Border>
          <TextBlock Text="Nothing here yet"
                     Foreground="{DynamicResource AppTextBrush}" FontSize="20" FontWeight="SemiBold"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="Follow some people to see their posts here."
                     Foreground="{DynamicResource AppSubtextBrush}" FontSize="13"
                     HorizontalAlignment="Center" Opacity="0.8"
                     TextWrapping="Wrap" TextAlignment="Center" MaxWidth="320"/>
        </StackPanel>

        <ItemsControl ItemsSource="{Binding Posts}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <ContentControl Content="{Binding}"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

  </Grid>

  <UserControl.Styles>
    <Style Selector="Button.refreshBtn">
      <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="14,9"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style Selector="Button.refreshBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource AppTextBrush}"/>
    </Style>
    <!-- keep old tabBtn alias for safety -->
    <Style Selector="Button.tabBtn">
      <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.tabBtn:pointerover /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="{DynamicResource AppTextBrush}"/>
    </Style>
    <Style Selector="Button.storyBubbleBtn">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.storyBubbleBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#01000000"/>
    </Style>
  </UserControl.Styles>
</UserControl>
