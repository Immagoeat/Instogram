<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="AppBg">#140a0a</Color>
  <Color x:Key="AppSurface">#1e1010</Color>
  <Color x:Key="AppCard">#2a1510</Color>
  <Color x:Key="AppBorder">#4a2518</Color>
  <Color x:Key="AppText">#fff1e6</Color>
  <Color x:Key="AppSubtext">#c4895a</Color>
  <Color x:Key="AppAccent">#f97316</Color>
  <Color x:Key="AppAccentDim">#7c2d12</Color>
  <Color x:Key="AppInput">#201510</Color>

  <SolidColorBrush x:Key="AppBgBrush"      Color="{StaticResource AppBg}"/>
  <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurface}"/>
  <SolidColorBrush x:Key="AppCardBrush"    Color="{StaticResource AppCard}"/>
  <SolidColorBrush x:Key="AppBorderBrush"  Color="{StaticResource AppBorder}"/>
  <SolidColorBrush x:Key="AppTextBrush"    Color="{StaticResource AppText}"/>
  <SolidColorBrush x:Key="AppSubtextBrush" Color="{StaticResource AppSubtext}"/>
  <SolidColorBrush x:Key="AppAccentBrush"  Color="{StaticResource AppAccent}"/>
  <SolidColorBrush x:Key="AppAccentDimBrush" Color="{StaticResource AppAccentDim}"/>
  <SolidColorBrush x:Key="AppInputBrush"   Color="{StaticResource AppInput}"/>
</ResourceDictionary>
