<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InstogramApp.ViewModels"
             x:Class="InstogramApp.Views.DMListView">

  <Grid RowDefinitions="Auto,*">

    <!-- Header -->
    <Border Grid.Row="0" Background="#111111" Padding="20,14"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Text="Messages" Foreground="{DynamicResource AppTextBrush}" FontSize="20" FontWeight="Bold"/>
        </StackPanel>
        <Button Grid.Column="1" Click="OnNewMessage" Classes="iconBtn"
                ToolTip.Tip="New message" Content="✏"/>
      </Grid>
    </Border>

    <!-- Conversation list -->
    <ScrollViewer Grid.Row="1">
      <StackPanel>

        <TextBlock Text="No conversations yet. Hit ✏ to message someone."
                   Foreground="#555555" FontSize="14"
                   HorizontalAlignment="Center" Margin="0,48"
                   TextWrapping="Wrap"
                   IsVisible="{Binding NoConversations}"/>

        <ItemsControl ItemsSource="{Binding Conversations}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Click="OnOpenConversation" Tag="{Binding}"
                      Classes="convRow" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Grid ColumnDefinitions="52,*,Auto" Margin="4,0">
                  <!-- Avatar -->
                  <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                          Background="#8b5cf6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding AvatarLetter}"
                               Foreground="{DynamicResource AppTextBrush}" FontWeight="Bold" FontSize="18"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <!-- Name + snippet -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" Margin="12,0,0,0">
                    <TextBlock Text="{Binding Partner.DisplayName}"
                               Foreground="{DynamicResource AppTextBrush}" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="{Binding LastSnippet}"
                               Foreground="#777777" FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                  <!-- Time + unread badge -->
                  <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding TimeLabel}" Foreground="#555555" FontSize="11"/>
                    <Border Background="#8b5cf6" CornerRadius="10" Padding="6,2"
                            HorizontalAlignment="Right"
                            IsVisible="{Binding HasUnread}">
                      <TextBlock Text="{Binding UnreadCount}" Foreground="{DynamicResource AppTextBrush}"
                                 FontSize="11" FontWeight="Bold"/>
                    </Border>
                  </StackPanel>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

  </Grid>

  <UserControl.Styles>
    <Style Selector="Button.convRow">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.convRow:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#161616"/>
    </Style>
    <Style Selector="Button.iconBtn">
      <Setter Property="Background" Value="#1e1e1e"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </UserControl.Styles>
</UserControl>
