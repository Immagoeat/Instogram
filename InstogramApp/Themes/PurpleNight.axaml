<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="AppBg">#0a0414</Color>
  <Color x:Key="AppSurface">#120820</Color>
  <Color x:Key="AppCard">#1a0f2e</Color>
  <Color x:Key="AppBorder">#2d1b4e</Color>
  <Color x:Key="AppText">#f0e8ff</Color>
  <Color x:Key="AppSubtext">#9d7ecf</Color>
  <Color x:Key="AppAccent">#a855f7</Color>
  <Color x:Key="AppAccentDim">#581c87</Color>
  <Color x:Key="AppInput">#1a1030</Color>

  <SolidColorBrush x:Key="AppBgBrush"      Color="{StaticResource AppBg}"/>
  <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurface}"/>
  <SolidColorBrush x:Key="AppCardBrush"    Color="{StaticResource AppCard}"/>
  <SolidColorBrush x:Key="AppBorderBrush"  Color="{StaticResource AppBorder}"/>
  <SolidColorBrush x:Key="AppTextBrush"    Color="{StaticResource AppText}"/>
  <SolidColorBrush x:Key="AppSubtextBrush" Color="{StaticResource AppSubtext}"/>
  <SolidColorBrush x:Key="NavIconBrush"    Color="#9d7ecf"/>
  <SolidColorBrush x:Key="AppAccentBrush"  Color="{StaticResource AppAccent}"/>
  <SolidColorBrush x:Key="AppAccentDimBrush" Color="{StaticResource AppAccentDim}"/>
  <SolidColorBrush x:Key="AppInputBrush"   Color="{StaticResource AppInput}"/>
  <!-- Override FluentTheme TextBox state backgrounds to kill watermark highlight -->
  <SolidColorBrush x:Key="TextControlBackground"              Color="{StaticResource AppInput}"/>
  <SolidColorBrush x:Key="TextControlBackgroundPointerOver"   Color="{StaticResource AppInput}"/>
  <SolidColorBrush x:Key="TextControlBackgroundFocused"       Color="{StaticResource AppInput}"/>
  <SolidColorBrush x:Key="TextControlBackgroundDisabled"      Color="{StaticResource AppInput}"/>
</ResourceDictionary>
