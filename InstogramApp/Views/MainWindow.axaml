<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:InstogramApp.ViewModels"
        xmlns:conv="using:InstogramApp.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="680"
        x:Class="InstogramApp.Views.MainWindow"
        Icon="/Assets/instogram.ico"
        Title="Instogram"
        MinWidth="720" MinHeight="520"
        Background="{DynamicResource AppBgBrush}">

  <Window.Resources>
    <conv:PathToBitmapConverter x:Key="PathToBitmap"/>
  </Window.Resources>

  <Grid ColumnDefinitions="230,*">

    <!-- Sidebar -->
    <Border Grid.Column="0" Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*,Auto">

        <!-- Brand -->
        <StackPanel Grid.Row="0">
          <Border Height="3">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Color="#7c3aed" Offset="0"/>
                <GradientStop Color="#a855f7" Offset="0.4"/>
                <GradientStop Color="#ec4899" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <Border Padding="18,18,18,16">
            <StackPanel Orientation="Horizontal" Spacing="11">
              <Border Width="38" Height="38" CornerRadius="12">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#7c3aed" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <Viewbox Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="White" Data="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <StackPanel VerticalAlignment="Center" Spacing="1">
                <TextBlock Text="Instogram" FontSize="19" FontWeight="Bold"
                           Foreground="{DynamicResource AppTextBrush}" LetterSpacing="0.3"/>
                <TextBlock Text="Share your world." FontSize="10.5"
                           Foreground="{DynamicResource AppSubtextBrush}" LetterSpacing="0.3"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Nav items -->
        <StackPanel Grid.Row="1" Margin="10,4,10,8" Spacing="1">

          <Button Click="NavHome" IsVisible="{Binding IsLoggedIn}"
                  Name="NavHomeBtn"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Classes="navBtn">
            <Grid ColumnDefinitions="3,40,*">
              <Border Grid.Column="0" Width="3" Height="22" CornerRadius="2"
                      VerticalAlignment="Center" Classes="navBar">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Border Grid.Column="1" Width="32" Height="32" CornerRadius="9"
                      Classes="navIconBg" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource NavIconBrush}" Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <TextBlock Grid.Column="2" Text="Home" VerticalAlignment="Center"
                         FontSize="13.5" FontWeight="Medium" Margin="2,0,0,0"/>
            </Grid>
          </Button>

          <Button Click="NavExplore" IsVisible="{Binding IsLoggedIn}"
                  Name="NavExploreBtn"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Classes="navBtn">
            <Grid ColumnDefinitions="3,40,*">
              <Border Grid.Column="0" Width="3" Height="22" CornerRadius="2"
                      VerticalAlignment="Center" Classes="navBar">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Border Grid.Column="1" Width="32" Height="32" CornerRadius="9"
                      Classes="navIconBg" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource NavIconBrush}" Data="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <TextBlock Grid.Column="2" Text="Explore" VerticalAlignment="Center"
                         FontSize="13.5" FontWeight="Medium" Margin="2,0,0,0"/>
            </Grid>
          </Button>

          <Button Click="NavNewPost" IsVisible="{Binding IsLoggedIn}"
                  Name="NavNewPostBtn"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Classes="navBtn">
            <Grid ColumnDefinitions="3,40,*">
              <Border Grid.Column="0" Width="3" Height="22" CornerRadius="2"
                      VerticalAlignment="Center" Classes="navBar">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Border Grid.Column="1" Width="32" Height="32" CornerRadius="9"
                      Classes="navIconBg" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource NavIconBrush}" Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <TextBlock Grid.Column="2" Text="New Post" VerticalAlignment="Center"
                         FontSize="13.5" FontWeight="Medium" Margin="2,0,0,0"/>
            </Grid>
          </Button>

          <Button Click="NavNewStory" IsVisible="{Binding IsLoggedIn}"
                  Name="NavNewStoryBtn"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Classes="navBtn">
            <Grid ColumnDefinitions="3,40,*">
              <Border Grid.Column="0" Width="3" Height="22" CornerRadius="2"
                      VerticalAlignment="Center" Classes="navBar">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Border Grid.Column="1" Width="32" Height="32" CornerRadius="9"
                      Classes="navIconBg" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource NavIconBrush}" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <TextBlock Grid.Column="2" Text="New Story" VerticalAlignment="Center"
                         FontSize="13.5" FontWeight="Medium" Margin="2,0,0,0"/>
            </Grid>
          </Button>

          <Button Click="NavMessages" IsVisible="{Binding IsLoggedIn}"
                  Name="NavMessagesBtn"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Classes="navBtn">
            <Grid ColumnDefinitions="3,40,*">
              <Border Grid.Column="0" Width="3" Height="22" CornerRadius="2"
                      VerticalAlignment="Center" Classes="navBar">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Border Grid.Column="1" Width="32" Height="32" CornerRadius="9"
                      Classes="navIconBg" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource NavIconBrush}" Data="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <TextBlock Grid.Column="2" Text="Messages" VerticalAlignment="Center"
                         FontSize="13.5" FontWeight="Medium" Margin="2,0,0,0"/>
            </Grid>
          </Button>

          <Button Click="NavFriendCall" IsVisible="{Binding IsLoggedIn}"
                  Name="NavCallBtn"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Classes="navBtn">
            <Grid ColumnDefinitions="3,40,*">
              <Border Grid.Column="0" Width="3" Height="22" CornerRadius="2"
                      VerticalAlignment="Center" Classes="navBar">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Border Grid.Column="1" Width="32" Height="32" CornerRadius="9"
                      Classes="navIconBg" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource NavIconBrush}" Data="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <TextBlock Grid.Column="2" Text="Call" VerticalAlignment="Center"
                         FontSize="13.5" FontWeight="Medium" Margin="2,0,0,0"/>
            </Grid>
          </Button>

          <!-- Notifications with badge -->
          <Button Click="NavNotifications" IsVisible="{Binding IsLoggedIn}"
                  Name="NavNotifBtn"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Classes="navBtn">
            <Grid ColumnDefinitions="3,40,*,Auto">
              <Border Grid.Column="0" Width="3" Height="22" CornerRadius="2"
                      VerticalAlignment="Center" Classes="navBar">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Border Grid.Column="1" Width="32" Height="32" CornerRadius="9"
                      Classes="navIconBg" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource NavIconBrush}" Data="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <TextBlock Grid.Column="2" Text="Notifications" VerticalAlignment="Center"
                         FontSize="13.5" FontWeight="Medium" Margin="2,0,0,0"/>
              <Border Grid.Column="3" CornerRadius="10"
                      Padding="7,2" IsVisible="{Binding HasNotifications}"
                      VerticalAlignment="Center" Margin="0,0,4,0">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="{Binding NotificationCount}" Foreground="White"
                           FontSize="10" FontWeight="Bold"/>
              </Border>
            </Grid>
          </Button>

          <Button Click="NavFriends"
                  Name="NavFriendsBtn"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Classes="navBtn">
            <Grid ColumnDefinitions="3,40,*">
              <Border Grid.Column="0" Width="3" Height="22" CornerRadius="2"
                      VerticalAlignment="Center" Classes="navBar">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Border Grid.Column="1" Width="32" Height="32" CornerRadius="9"
                      Classes="navIconBg" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource NavIconBrush}" Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <TextBlock Grid.Column="2" Text="Friends" VerticalAlignment="Center"
                         FontSize="13.5" FontWeight="Medium" Margin="2,0,0,0"/>
            </Grid>
          </Button>

          <Button Click="NavSettings"
                  Name="NavSettingsBtn"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Classes="navBtn">
            <Grid ColumnDefinitions="3,40,*">
              <Border Grid.Column="0" Width="3" Height="22" CornerRadius="2"
                      VerticalAlignment="Center" Classes="navBar">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Border Grid.Column="1" Width="32" Height="32" CornerRadius="9"
                      Classes="navIconBg" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource NavIconBrush}" Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <TextBlock Grid.Column="2" Text="Settings" VerticalAlignment="Center"
                         FontSize="13.5" FontWeight="Medium" Margin="2,0,0,0"/>
            </Grid>
          </Button>

          <Button Click="NavProfile" IsVisible="{Binding IsLoggedIn}"
                  Name="NavProfileBtn"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Classes="navBtn">
            <Grid ColumnDefinitions="3,40,*">
              <Border Grid.Column="0" Width="3" Height="22" CornerRadius="2"
                      VerticalAlignment="Center" Classes="navBar">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Border Grid.Column="1" Width="32" Height="32" CornerRadius="9"
                      Classes="navIconBg" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{DynamicResource NavIconBrush}" Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <TextBlock Grid.Column="2" Text="Profile" VerticalAlignment="Center"
                         FontSize="13.5" FontWeight="Medium" Margin="2,0,0,0"/>
            </Grid>
          </Button>

          <!-- Admin panel (masters only) -->
          <Button Click="NavAdmin"
                  Name="NavAdminBtn"
                  IsVisible="{Binding IsMaster}"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Classes="navBtn">
            <Grid ColumnDefinitions="3,40,*">
              <Border Grid.Column="0" Width="3" Height="22" CornerRadius="2"
                      VerticalAlignment="Center" Classes="navBar">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#f59e0b" Offset="0"/>
                    <GradientStop Color="#ef4444" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
              <Border Grid.Column="1" Width="32" Height="32" CornerRadius="9"
                      Background="#251a08" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Fill="#f59e0b" Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <TextBlock Grid.Column="2" Text="Admin" VerticalAlignment="Center"
                         FontSize="13.5" FontWeight="Medium" Margin="2,0,0,0" Foreground="#f59e0b"/>
            </Grid>
          </Button>

        </StackPanel>

        <!-- User card + logout -->
        <Border Grid.Row="2" Padding="10,0,10,14" IsVisible="{Binding IsLoggedIn}">
          <StackPanel Spacing="8">
            <Border Height="1" Background="{DynamicResource AppBorderBrush}" Margin="6,0" Opacity="0.6"/>
            <Border Background="{DynamicResource AppCardBrush}" CornerRadius="14" Padding="10,10"
                    BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
              <Grid ColumnDefinitions="42,*,Auto">
                <Grid Grid.Column="0" Width="36" Height="36">
                  <!-- Gradient ring for avatar -->
                  <Border Width="36" Height="36" CornerRadius="18"
                          IsVisible="{Binding SidebarHasAvatar}">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#8b5cf6" Offset="0"/>
                        <GradientStop Color="#ec4899" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                  </Border>
                  <Border CornerRadius="16" ClipToBounds="True"
                          Width="32" Height="32"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          IsVisible="{Binding SidebarHasAvatar}">
                    <Image Source="{Binding SidebarAvatarPath, Converter={StaticResource PathToBitmap}}"
                           Stretch="UniformToFill" Width="32" Height="32"/>
                  </Border>
                  <Border Width="36" Height="36" CornerRadius="18"
                          Background="{Binding SidebarAccent}"
                          IsVisible="{Binding SidebarHasNoAvatar}">
                    <TextBlock Text="{Binding LoggedInAs[1]}"
                               Foreground="White" FontWeight="Bold" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                </Grid>
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding LoggedInDisplay}" Foreground="{DynamicResource AppTextBrush}"
                             FontSize="13" FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"/>
                  <TextBlock Text="{Binding LoggedInAs}" Foreground="{DynamicResource AppSubtextBrush}"
                             FontSize="11"/>
                </StackPanel>
                <Button Grid.Column="2" Click="NavLogout"
                        Classes="logoutBtn" ToolTip.Tip="Log out">
                  <Viewbox Width="15" Height="15">
                    <Canvas Width="24" Height="24">
                      <Path Fill="{DynamicResource AppSubtextBrush}"
                            Data="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/>
                    </Canvas>
                  </Viewbox>
                </Button>
              </Grid>
            </Border>
          </StackPanel>
        </Border>

      </Grid>
    </Border>

    <!-- Main content -->
    <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>

  </Grid>

  <Window.Styles>
    <Style Selector="Button.navBtn">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="FontSize" Value="13.5"/>
      <Setter Property="Padding" Value="4,8"/>
      <Setter Property="CornerRadius" Value="11"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.navBtn Border.navBar">
      <Setter Property="Opacity" Value="0"/>
    </Style>
    <Style Selector="Button.navBtn Border.navIconBg">
      <Setter Property="Background" Value="#01000000"/>
    </Style>
    <Style Selector="Button.navBtn.active Border.navBar">
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.navBtn.active">
      <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
    </Style>
    <Style Selector="Button.navBtn.active Border.navIconBg">
      <Setter Property="Background" Value="{DynamicResource AppAccentDimBrush}"/>
    </Style>
    <Style Selector="Button.navBtn.active /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource AppTextBrush}"/>
    </Style>
    <Style Selector="Button.navBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource AppTextBrush}"/>
    </Style>
    <Style Selector="Button.navBtn:pointerover Border.navIconBg">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
    </Style>
    <Style Selector="Button.logoutBtn">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="Padding" Value="7,7"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="CornerRadius" Value="9"/>
    </Style>
    <Style Selector="Button.logoutBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2a1010"/>
    </Style>
  </Window.Styles>
</Window>
