<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InstogramApp.Views.ExploreView">

  <Grid RowDefinitions="Auto,*">

    <Border Grid.Row="0" Background="{DynamicResource AppSurfaceBrush}" Padding="24,14"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock Text="Explore" Foreground="{DynamicResource AppTextBrush}" FontSize="20" FontWeight="Bold"/>
          <TextBlock Text="Trending across Instogram" Foreground="#444444" FontSize="12"/>
        </StackPanel>
        <Button Grid.Column="1" Click="DoRefresh" Content="↻ Refresh"
                Classes="tabBtn" VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" Padding="28,20">
      <ItemsControl ItemsSource="{Binding Posts}" MaxWidth="680" HorizontalAlignment="Center">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ContentControl Content="{Binding}"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </Grid>

  <UserControl.Styles>
    <Style Selector="Button.tabBtn">
      <Setter Property="Background" Value="#1a1a1a"/>
      <Setter Property="Foreground" Value="#aaaaaa"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="14,7"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
  </UserControl.Styles>
</UserControl>
