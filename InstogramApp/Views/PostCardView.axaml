<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="using:InstogramApp.Controls"
             x:Class="InstogramApp.Views.PostCardView">

  <Border Background="{DynamicResource AppCardBrush}" CornerRadius="16" Padding="20,18"
          Margin="0,0,0,16"
          BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
    <StackPanel Spacing="14">

      <!-- Author row -->
      <Grid ColumnDefinitions="46,*,Auto">
        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="21"
                Background="{Binding AuthorAccent}">
          <TextBlock Text="{Binding AuthorInitial}"
                     Foreground="White" FontWeight="Bold" FontSize="18"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
          <Button Click="OnOpenAuthor" Classes="authorBtn">
            <TextBlock Text="{Binding AuthorDisplayName}"
                       Foreground="{DynamicResource AppTextBrush}"
                       FontWeight="SemiBold" FontSize="15"/>
          </Button>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="{Binding AuthorUsername}"
                       Foreground="#555555" FontSize="12"/>
            <TextBlock Text="·" Foreground="#333333" FontSize="12"/>
            <TextBlock Text="{Binding TimeLabel}"
                       Foreground="#555555" FontSize="12"/>
          </StackPanel>
        </StackPanel>
        <!-- More menu placeholder — polished look -->
        <TextBlock Grid.Column="2" Text="···" Foreground="#3a3a3a"
                   FontSize="18" VerticalAlignment="Center" Margin="0,0,2,4"/>
      </Grid>

      <!-- Caption -->
      <TextBlock Text="{Binding Caption}" Foreground="{DynamicResource AppTextBrush}"
                 TextWrapping="Wrap" FontSize="15" LineHeight="24"
                 IsVisible="{Binding Caption,
                 Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

      <!-- Post image -->
      <Border CornerRadius="12" ClipToBounds="True" IsVisible="{Binding HasImage}"
              MaxHeight="520">
        <ctl:AsyncImage Source="{Binding ImageUrl}"/>
      </Border>

      <!-- Tags -->
      <ItemsControl ItemsSource="{Binding Tags}" IsVisible="{Binding HasTags}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="#160e2e" CornerRadius="6" Padding="9,3" Margin="0,0,6,4">
              <TextBlock Text="{Binding StringFormat='#{0}'}"
                         Foreground="#8b5cf6" FontSize="12" FontWeight="Medium"/>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Divider -->
      <Border Height="1" Background="{DynamicResource AppBorderBrush}" Opacity="0.6"/>

      <!-- Actions row -->
      <StackPanel Orientation="Horizontal" Spacing="6">
        <Button Click="OnLike" Classes="actionBtn" Content="{Binding LikeLabel}"/>
        <Border Width="1" Background="{DynamicResource AppBorderBrush}" Margin="4,4"/>
        <TextBlock Text="{Binding CommentCount, StringFormat='{}{0} comments'}"
                   Foreground="#555555" VerticalAlignment="Center" FontSize="13"/>
      </StackPanel>

      <!-- Comment previews -->
      <ItemsControl ItemsSource="{Binding CommentPreviews}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}" Foreground="#777777" FontSize="13"
                       TextWrapping="Wrap" Margin="0,2"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Add comment -->
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0" Text="{Binding CommentText}"
                 PlaceholderText="Write a comment…" Classes="commentInput"/>
        <Button Grid.Column="1" Click="OnAddComment"
                Content="Post" Classes="commentBtn" Margin="8,0,0,0"/>
      </Grid>

    </StackPanel>
  </Border>

  <UserControl.Styles>
    <Style Selector="Button.authorBtn">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Margin" Value="0"/>
    </Style>
    <Style Selector="Button.authorBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="TextElement.Foreground" Value="#a78bfa"/>
    </Style>
    <Style Selector="Button.actionBtn">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#777777"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.actionBtn:pointerover /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="#a78bfa"/>
    </Style>
    <Style Selector="TextBox.commentInput">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="Padding" Value="14,9"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="TextBox.commentInput /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
    </Style>
    <Style Selector="TextBox.commentInput:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
    </Style>
    <Style Selector="TextBox.commentInput:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.commentInput:focus-within /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.commentInput /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="#555555"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.commentBtn">
      <Setter Property="Background" Value="#7c3aed"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="14,9"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.commentBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#6d28d9"/>
    </Style>
  </UserControl.Styles>
</UserControl>
