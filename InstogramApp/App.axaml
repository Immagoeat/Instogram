<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:InstogramApp"
             x:Class="InstogramApp.App"
             RequestedThemeVariant="Dark">

  <Application.DataTemplates>
    <local:ViewLocator/>
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme/>

    <!-- Global theme-aware styles — driven by DynamicResource, update on theme switch -->
    <Style Selector="Window">
      <Setter Property="Background" Value="{DynamicResource AppBgBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
    </Style>
    <Style Selector="UserControl">
      <Setter Property="Background" Value="{DynamicResource AppBgBrush}"/>
    </Style>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="CaretBrush"  Value="{DynamicResource AppTextBrush}"/>
      <Setter Property="SelectionBrush" Value="#8b5cf6"/>
    </Style>
    <!-- Override every state FluentTheme changes on TextBox itself -->
    <Style Selector="TextBox:pointerover">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
    </Style>
    <Style Selector="TextBox:focus:pointerover">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
    </Style>
    <!-- Kill FluentTheme inner-border glow/highlight on every state -->
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox:focus:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox:focus-within /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox:watermark /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style Selector="TextBox:watermark:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <!-- Kill the focus adorner (dotted rectangle) entirely -->
    <Style Selector="TextBox:focus-within">
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <!-- Placeholder text colour locked -->
    <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="#666666"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="TextBox:pointerover /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="#666666"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="TextBox:focus /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="#666666"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="ScrollViewer">
      <Setter Property="Background" Value="{DynamicResource AppBgBrush}"/>
    </Style>
  </Application.Styles>
</Application>
