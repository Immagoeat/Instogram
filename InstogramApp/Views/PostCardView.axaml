<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="using:InstogramApp.Controls"
             x:Class="InstogramApp.Views.PostCardView">

  <Border Background="{DynamicResource AppCardBrush}" CornerRadius="20" Padding="0"
          Margin="0,0,0,20"
          BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
    <StackPanel Spacing="0">

      <!-- Author row -->
      <Grid ColumnDefinitions="64,*,Auto" Margin="18,18,14,0">
        <!-- Avatar with gradient ring -->
        <Grid Grid.Column="0" Width="50" Height="50">
          <!-- Outer gradient ring -->
          <Border Width="50" Height="50" CornerRadius="25">
            <Border.Background>
              <LinearGradientBrush StartPoint="45%,0%" EndPoint="100%,100%">
                <GradientStop Color="#7c3aed" Offset="0"/>
                <GradientStop Color="#ec4899" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <!-- Inner avatar -->
          <Border Width="46" Height="46" CornerRadius="23"
                  Background="{Binding AuthorAccent}"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding AuthorInitial}"
                       Foreground="White" FontWeight="Bold" FontSize="19"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </Grid>

        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
          <Button Click="OnOpenAuthor" Classes="authorBtn">
            <TextBlock Text="{Binding AuthorDisplayName}"
                       Foreground="{DynamicResource AppTextBrush}"
                       FontWeight="Bold" FontSize="15"/>
          </Button>
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="{Binding AuthorUsername}"
                       Foreground="{DynamicResource AppSubtextBrush}" FontSize="12"/>
            <TextBlock Text="·" Foreground="{DynamicResource AppSubtextBrush}" FontSize="12"/>
            <TextBlock Text="{Binding TimeLabel}"
                       Foreground="{DynamicResource AppSubtextBrush}" FontSize="12"/>
          </StackPanel>
        </StackPanel>

        <!-- 3-dot menu button -->
        <Button Grid.Column="2" Click="OnMenuToggle" Classes="menuDotBtn"
                VerticalAlignment="Top" Margin="0,6,0,0">
          <StackPanel Orientation="Vertical" Spacing="3.5" Margin="2,2">
            <Ellipse Width="3.5" Height="3.5" Fill="{DynamicResource AppSubtextBrush}"/>
            <Ellipse Width="3.5" Height="3.5" Fill="{DynamicResource AppSubtextBrush}"/>
            <Ellipse Width="3.5" Height="3.5" Fill="{DynamicResource AppSubtextBrush}"/>
          </StackPanel>
        </Button>
      </Grid>

      <!-- Dropdown menu -->
      <Border IsVisible="{Binding MenuOpen}"
              Background="{DynamicResource AppSurfaceBrush}"
              BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
              CornerRadius="14" Margin="16,8,16,0" Padding="4">
        <StackPanel Spacing="0">
          <Button Click="OnShare" Classes="menuItem">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Viewbox Width="15" Height="15">
                <Canvas Width="24" Height="24">
                  <Path Fill="{DynamicResource AppTextBrush}"
                        Data="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/>
                </Canvas>
              </Viewbox>
              <TextBlock Text="Share post" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Click="OnReport" Classes="menuItem"
                  IsVisible="{Binding IsNotMyPost}">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Viewbox Width="15" Height="15">
                <Canvas Width="24" Height="24">
                  <Path Fill="#f87171"
                        Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                </Canvas>
              </Viewbox>
              <TextBlock Text="Report post" Foreground="#f87171" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Click="OnDelete" Classes="menuItem"
                  IsVisible="{Binding IsMyPost}">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Viewbox Width="15" Height="15">
                <Canvas Width="24" Height="24">
                  <Path Fill="#f87171"
                        Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                </Canvas>
              </Viewbox>
              <TextBlock Text="Delete post" Foreground="#f87171" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Border IsVisible="{Binding MenuStatus,
                  Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  Background="{DynamicResource AppCardBrush}" CornerRadius="10"
                  Padding="12,8" Margin="4,2">
            <TextBlock Text="{Binding MenuStatus}"
                       Foreground="{DynamicResource AppAccentBrush}"
                       FontSize="12" TextWrapping="Wrap"/>
          </Border>
        </StackPanel>
      </Border>

      <!-- Caption -->
      <TextBlock Text="{Binding Caption}" Foreground="{DynamicResource AppTextBrush}"
                 TextWrapping="Wrap" FontSize="15" LineHeight="24"
                 Margin="20,14,20,0"
                 IsVisible="{Binding Caption,
                 Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

      <!-- Post image (full-bleed with rounded bottom) -->
      <Border ClipToBounds="True" IsVisible="{Binding HasImage}"
              MaxHeight="540" Margin="0,14,0,0">
        <ctl:AsyncImage Source="{Binding ImageUrl}"/>
      </Border>

      <!-- Post video indicator -->
      <Border IsVisible="{Binding HasVideo}"
              Margin="20,14,20,0" Padding="0">
        <Border CornerRadius="14" ClipToBounds="True">
          <Border Padding="20,18">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#1a0d3a" Offset="0"/>
                <GradientStop Color="#2d0f30" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
              <Border CornerRadius="30" Width="56" Height="56">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#7c3aed" Offset="0"/>
                    <GradientStop Color="#ec4899" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <Viewbox Width="28" Height="28">
                  <Canvas Width="24" Height="24">
                    <Path Fill="White" Data="M8 5v14l11-7z"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <StackPanel VerticalAlignment="Center" Spacing="3">
                <TextBlock Text="Video post" Foreground="White"
                           FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Text="Video playback coming soon" Foreground="#9a80c0"
                           FontSize="12"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </Border>
      </Border>

      <!-- Tags -->
      <ItemsControl ItemsSource="{Binding Tags}" IsVisible="{Binding HasTags}"
                    Margin="20,12,20,0">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{DynamicResource AppAccentDimBrush}" CornerRadius="8"
                    Padding="10,4" Margin="0,0,6,4">
              <TextBlock Text="{Binding StringFormat='#{0}'}"
                         Foreground="{DynamicResource AppAccentBrush}"
                         FontSize="12" FontWeight="Medium"/>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Divider -->
      <Border Height="1" Background="{DynamicResource AppBorderBrush}"
              Margin="20,14,20,0" Opacity="0.6"/>

      <!-- Actions row -->
      <StackPanel Orientation="Horizontal" Spacing="4" Margin="14,8,14,0">
        <!-- Like button -->
        <Button Click="OnLike" Classes="actionBtn" Padding="12,8">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <Viewbox Width="17" Height="17">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource AppSubtextBrush}"
                      Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </Canvas>
            </Viewbox>
            <TextBlock Text="{Binding LikeLabel}" VerticalAlignment="Center" FontSize="13"/>
          </StackPanel>
        </Button>

        <!-- Comment count -->
        <Button Classes="actionBtn" Padding="12,8">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <Viewbox Width="17" Height="17">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource AppSubtextBrush}"
                      Data="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </Canvas>
            </Viewbox>
            <TextBlock Text="{Binding CommentCount, StringFormat='{}{0}'}"
                       VerticalAlignment="Center" FontSize="13"/>
          </StackPanel>
        </Button>
      </StackPanel>

      <!-- Comment previews -->
      <ItemsControl ItemsSource="{Binding CommentPreviews}" Margin="20,8,20,0">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}" Foreground="{DynamicResource AppSubtextBrush}"
                       FontSize="13" TextWrapping="Wrap" Margin="0,2"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Add comment -->
      <Grid ColumnDefinitions="*,Auto" Margin="16,10,16,16">
        <TextBox Grid.Column="0" Text="{Binding CommentText}"
                 PlaceholderText="Write a comment…" Classes="commentInput"/>
        <Button Grid.Column="1" Click="OnAddComment"
                Content="Post" Classes="commentBtn" Margin="8,0,0,0"/>
      </Grid>

    </StackPanel>
  </Border>

  <UserControl.Styles>
    <Style Selector="Button.authorBtn">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Margin" Value="0"/>
    </Style>
    <Style Selector="Button.authorBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource AppAccentBrush}"/>
    </Style>
    <Style Selector="Button.menuDotBtn">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.menuDotBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
    </Style>
    <Style Selector="Button.menuItem">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.menuItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
    </Style>
    <Style Selector="Button.actionBtn">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.actionBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource AppAccentBrush}"/>
    </Style>
    <Style Selector="TextBox.commentInput">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="TextBox.commentInput /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
    </Style>
    <Style Selector="TextBox.commentInput:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
    </Style>
    <Style Selector="TextBox.commentInput:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.commentInput:focus-within /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="TextBox.commentInput /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="{DynamicResource AppSubtextBrush}"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.commentBtn">
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="18,10"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.commentBtn /template/ ContentPresenter">
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
            <GradientStop Color="#7c3aed" Offset="0"/>
            <GradientStop Color="#a855f7" Offset="1"/>
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
    </Style>
    <Style Selector="Button.commentBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppAccentDimBrush}"/>
    </Style>
  </UserControl.Styles>
</UserControl>
