<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InstogramApp.Views.NotificationsView">

  <Grid RowDefinitions="Auto,*">

    <Border Grid.Row="0" Background="{DynamicResource AppSurfaceBrush}" Padding="24,14"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
      <StackPanel Spacing="2">
        <TextBlock Text="Notifications" Foreground="{DynamicResource AppTextBrush}" FontSize="20" FontWeight="Bold"/>
        <TextBlock Text="Messages, posts, and activity" Foreground="#444444" FontSize="12"/>
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1">
      <StackPanel>

        <TextBlock Text="You're all caught up ✓"
                   Foreground="#3a3a3a" FontSize="15"
                   HorizontalAlignment="Center" Margin="0,60"
                   IsVisible="{Binding HasNotifications,
                   Converter={x:Static BoolConverters.Not}}"/>

        <ItemsControl ItemsSource="{Binding Items}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Padding="20,14" BorderBrush="#1a1a1a" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="44,*,Auto">
                  <!-- Icon circle -->
                  <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19"
                          Background="#1e1340" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Icon}" FontSize="17"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <!-- Body -->
                  <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" Spacing="3">
                    <TextBlock Text="{Binding Body}" Foreground="#e0e0e0"
                               FontSize="13" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Time}" Foreground="#555555" FontSize="11"/>
                  </StackPanel>
                  <!-- Unread dot -->
                  <Ellipse Grid.Column="2" Width="8" Height="8" Fill="#8b5cf6"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           IsVisible="{Binding IsNew}"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

  </Grid>
</UserControl>
