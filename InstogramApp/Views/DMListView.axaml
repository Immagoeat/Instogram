<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InstogramApp.ViewModels"
             x:Class="InstogramApp.Views.DMListView">

  <Grid RowDefinitions="Auto,*">

    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource AppSurfaceBrush}" Padding="28,18"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
          <TextBlock Text="Messages" Foreground="{DynamicResource AppTextBrush}"
                     FontSize="24" FontWeight="Bold" LetterSpacing="0.2"/>
          <TextBlock Text="Your conversations" Foreground="{DynamicResource AppSubtextBrush}"
                     FontSize="12"/>
        </StackPanel>
        <Button Grid.Column="1" Click="OnNewMessage" Classes="iconBtn"
                ToolTip.Tip="New message">
          <Viewbox Width="16" Height="16">
            <Canvas Width="24" Height="24">
              <Path Fill="{DynamicResource AppTextBrush}"
                    Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
            </Canvas>
          </Viewbox>
        </Button>
      </Grid>
    </Border>

    <!-- Conversation list -->
    <ScrollViewer Grid.Row="1">
      <StackPanel Margin="0,8">

        <TextBlock Text="No conversations yet. Hit the pencil icon to message someone."
                   Foreground="{DynamicResource AppSubtextBrush}" FontSize="14"
                   HorizontalAlignment="Center" Margin="24,48"
                   TextWrapping="Wrap" TextAlignment="Center"
                   IsVisible="{Binding NoConversations}"/>

        <ItemsControl ItemsSource="{Binding Conversations}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Click="OnOpenConversation" Tag="{Binding}"
                      Classes="convRow" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Grid ColumnDefinitions="56,*,Auto" Margin="4,0">
                  <!-- Avatar with accent ring on unread -->
                  <Grid Grid.Column="0" Width="48" Height="48">
                    <Border Width="48" Height="48" CornerRadius="24"
                            Background="{DynamicResource AppAccentBrush}" Opacity="0.35"
                            IsVisible="{Binding HasUnread}"/>
                    <Border Width="44" Height="44" CornerRadius="22"
                            Background="{DynamicResource AppAccentBrush}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                      <TextBlock Text="{Binding AvatarLetter}"
                                 Foreground="White" FontWeight="Bold" FontSize="18"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                  </Grid>
                  <!-- Name + snippet -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3" Margin="14,0,0,0">
                    <TextBlock Text="{Binding Partner.DisplayName}"
                               Foreground="{DynamicResource AppTextBrush}"
                               FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="{Binding LastSnippet}"
                               Foreground="{DynamicResource AppSubtextBrush}" FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                  <!-- Time + unread badge -->
                  <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="5"
                              HorizontalAlignment="Right">
                    <TextBlock Text="{Binding TimeLabel}"
                               Foreground="{DynamicResource AppSubtextBrush}" FontSize="11"
                               HorizontalAlignment="Right"/>
                    <Border Background="{DynamicResource AppAccentBrush}" CornerRadius="12"
                            Padding="7,2" HorizontalAlignment="Right"
                            IsVisible="{Binding HasUnread}">
                      <TextBlock Text="{Binding UnreadCount}" Foreground="White"
                                 FontSize="11" FontWeight="Bold"/>
                    </Border>
                  </StackPanel>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

  </Grid>

  <UserControl.Styles>
    <Style Selector="Button.convRow">
      <Setter Property="Background" Value="#01000000"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.convRow:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
    </Style>
    <Style Selector="Button.iconBtn">
      <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="Padding" Value="10,10"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.iconBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
    </Style>
  </UserControl.Styles>
</UserControl>
